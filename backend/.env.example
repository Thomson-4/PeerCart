NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/peercart

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS)
CLIENT_URL=http://localhost:3000

# Base URL used to construct email verification links
EMAIL_VERIFY_BASE_URL=http://localhost:5000

# Email / SMTP (used in later rounds — mocked in Round 1)
EMAIL_FROM=noreply@peercart.in
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password

# Twilio (mocked in Round 1 — OTPs are console.log'd)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+10000000000

# Admin
ADMIN_SECRET=replace_with_a_long_random_admin_secret

# Razorpay (mock in Round 3 — wire SDK in production)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloudinary (for student ID photo uploads — wired in later rounds)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Anthropic — Round 7: AI price suggestions
ANTHROPIC_API_KEY=your_anthropic_api_key

# Firebase — Round 6: FCM push notifications
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
