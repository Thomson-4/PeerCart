{
  "name": "peercart-backend",
  "version": "1.0.0",
  "description": "PeerCart Campus — peer-to-peer college marketplace REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "demo:wipe": "node --dns-result-order=ipv4first scripts/wipeData.js",
    "demo:wipe-cloudinary": "node --dns-result-order=ipv4first scripts/wipeCloudinary.js",
    "demo:seed": "node --dns-result-order=ipv4first scripts/seedCampus.js",
    "demo:check": "node --dns-result-order=ipv4first scripts/demoCheck.js",
    "demo:setup": "node --dns-result-order=ipv4first scripts/wipeData.js && node --dns-result-order=ipv4first scripts/seedCampus.js && node --dns-result-order=ipv4first scripts/demoCheck.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
